# Server
PORT=5000
NODE_ENV=development
TRUST_PROXY=true
CLIENT_URL=https://staging.fixo.app
CLIENT_URLS=https://staging.fixo.app,https://staging-admin.fixo.app

# Request / connection tuning
BODY_LIMIT_MB=2
URL_ENCODED_LIMIT_MB=2
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000
MAX_REQUESTS_PER_SOCKET=2000
SLOW_REQUEST_THRESHOLD_MS=1000

# Monitoring / metrics
METRICS_ENABLED=true
METRICS_ROUTE=/api/metrics
METRICS_AUTH_TOKEN=replace-with-staging-metrics-token
METRICS_SERVICE_NAME=fixo-server-staging

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
MUTATION_RATE_LIMIT_MAX=80

# Idempotency
IDEMPOTENCY_TTL_MS=15000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/fixo_staging
MONGODB_MAX_POOL_SIZE=80
MONGODB_MIN_POOL_SIZE=5
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_MAX_IDLE_TIME_MS=30000

# Redis
REDIS_URL=redis://staging-redis:6379

# Socket.IO
SOCKET_PING_INTERVAL_MS=20000
SOCKET_PING_TIMEOUT_MS=25000
SOCKET_MAX_HTTP_BUFFER_SIZE=1000000

# JWT
JWT_SECRET=replace-with-staging-jwt-secret
JWT_EXPIRE=7d

# Admin bootstrap for `npm run seed`
ADMIN_SEED_EMAIL=fixo@princehub.in
ADMIN_SEED_PASSWORD=replace-with-staging-admin-password

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
GOOGLE_CLIENT_SECRET=

# Web Push
WEB_PUSH_ENABLED=true
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:staging-alerts@fixo.app
WEB_PUSH_TTL_SECONDS=3600

# Map endpoints
MAPCN_GEOCODE_URL=https://nominatim.openstreetmap.org/search
MAPCN_REVERSE_GEOCODE_URL=https://nominatim.openstreetmap.org/reverse
MAPCN_ROUTING_URL=https://router.project-osrm.org/route/v1/driving

# Jobs
JOB_STALE_BOOKING_MINUTES=30
JOB_CLEANUP_INTERVAL_MS=60000
