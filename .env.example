# Server Configuration
PORT=5000
NODE_ENV=development
TRUST_PROXY=false

# Request / connection tuning
BODY_LIMIT_MB=2
URL_ENCODED_LIMIT_MB=2
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000
MAX_REQUESTS_PER_SOCKET=5000
SLOW_REQUEST_THRESHOLD_MS=1500

# Monitoring / metrics
METRICS_ENABLED=true
METRICS_ROUTE=/api/metrics
METRICS_AUTH_TOKEN=
METRICS_SERVICE_NAME=fixo-server

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=30
MUTATION_RATE_LIMIT_MAX=150

# Idempotency
IDEMPOTENCY_TTL_MS=15000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/fixo
MONGODB_MAX_POOL_SIZE=120
MONGODB_MIN_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_MAX_IDLE_TIME_MS=30000

# Redis (recommended for multi-instance rate limiting + socket adapter)
REDIS_URL=

# Socket.IO reliability tuning
SOCKET_PING_INTERVAL_MS=20000
SOCKET_PING_TIMEOUT_MS=25000
SOCKET_MAX_HTTP_BUFFER_SIZE=1000000

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# Client URL
CLIENT_URL=http://localhost:3000

# Cloudinary (add your keys)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay (add your keys)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Web Push (offline/background browser notifications)
WEB_PUSH_ENABLED=true
WEB_PUSH_PUBLIC_KEY=your_web_push_public_key
WEB_PUSH_PRIVATE_KEY=your_web_push_private_key
WEB_PUSH_SUBJECT=mailto:alerts@fixo.app
WEB_PUSH_TTL_SECONDS=3600

# MapCN / Open Map Endpoints
MAPCN_GEOCODE_URL=https://nominatim.openstreetmap.org/search
MAPCN_REVERSE_GEOCODE_URL=https://nominatim.openstreetmap.org/reverse
MAPCN_ROUTING_URL=https://router.project-osrm.org/route/v1/driving

# Optional: multiple frontend origins (comma-separated)
# CLIENT_URLS=https://app.example.com,https://admin.example.com

# Background job tuning
JOB_STALE_BOOKING_MINUTES=3
JOB_CLEANUP_INTERVAL_MS=60000