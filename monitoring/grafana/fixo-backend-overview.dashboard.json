      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(fixo_http_requests_total{status_code=~\"5..\",service=~\"$service\",environment=~\"$environment\"}[5m])) / clamp_min(sum(rate(fixo_http_requests_total{service=~\"$service\",environment=~\"$environment\"}[5m])), 1)",
          "refId": "A"
        }
      ],
      "title": "API 5xx Error Ratio",
      "type": "timeseries"
