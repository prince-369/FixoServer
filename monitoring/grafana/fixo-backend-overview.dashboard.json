      },
      "targets": [
        {
          "expr": "sum(rate(fixo_http_requests_total{service=~\"$service\",environment=~\"$environment\"}[1m]))",
          "refId": "A"
        }
      ],
      "title": "API Throughput (req/sec)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
