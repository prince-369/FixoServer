# Server
PORT=5000
NODE_ENV=production
TRUST_PROXY=true
CLIENT_URL=https://fixo.app
CLIENT_URLS=https://fixo.app,https://admin.fixo.app

# Request / connection tuning
BODY_LIMIT_MB=2
URL_ENCODED_LIMIT_MB=2
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000
MAX_REQUESTS_PER_SOCKET=8000
SLOW_REQUEST_THRESHOLD_MS=800

# Monitoring / metrics
METRICS_ENABLED=true
METRICS_ROUTE=/api/metrics
METRICS_AUTH_TOKEN=replace-with-production-metrics-token
METRICS_SERVICE_NAME=fixo-server

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1200
AUTH_RATE_LIMIT_MAX=50
MUTATION_RATE_LIMIT_MAX=250

# Idempotency
IDEMPOTENCY_TTL_MS=30000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/fixo_prod
MONGODB_MAX_POOL_SIZE=300
MONGODB_MIN_POOL_SIZE=20
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_MAX_IDLE_TIME_MS=30000

# Redis
REDIS_URL=redis://prod-redis:6379

# Socket.IO
SOCKET_PING_INTERVAL_MS=20000
SOCKET_PING_TIMEOUT_MS=25000
SOCKET_MAX_HTTP_BUFFER_SIZE=1000000

# JWT
JWT_SECRET=replace-with-production-jwt-secret
JWT_EXPIRE=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web Push
WEB_PUSH_ENABLED=true
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:alerts@fixo.app
WEB_PUSH_TTL_SECONDS=3600

# Map endpoints
MAPCN_GEOCODE_URL=https://nominatim.openstreetmap.org/search
MAPCN_REVERSE_GEOCODE_URL=https://nominatim.openstreetmap.org/reverse
MAPCN_ROUTING_URL=https://router.project-osrm.org/route/v1/driving

# Jobs
JOB_STALE_BOOKING_MINUTES=3
JOB_CLEANUP_INTERVAL_MS=30000
